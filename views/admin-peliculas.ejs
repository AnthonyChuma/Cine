<%
const h = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
const lista = Array.isArray(peliculas) ? peliculas : [];
const salasList = Array.isArray(salas) ? salas : [];
const content = `
  <section class="page-heading compact-heading">
    <span class="eyebrow">Administración</span>
    <h1>Películas</h1>
    <p>Gestiona las películas disponibles en cartelera y crea funciones por sala.</p>
  </section>

  <section class="admin-grid-layout">
    <form method="POST" action="/admin/peliculas" class="form-card admin-form">
      <h2>Agregar película</h2>
      <label>Título</label>
      <input name="titulo" placeholder="Título de la película" required />
      <label>Sinopsis</label>
      <textarea name="sinopsis" placeholder="Descripción corta"></textarea>
      <div class="two-cols">
        <div><label>Duración</label><input name="duracion_minutos" type="number" placeholder="Minutos" required /></div>
        <div><label>Clasificación</label><input name="clasificacion" placeholder="ATP, +14" required /></div>
      </div>
      <label>URL de imagen</label>
      <input name="imagen_url" placeholder="https://..." />
      <label>URL de tráiler</label>
      <input name="trailer_url" placeholder="https://..." />
      <div class="two-cols">
        <div><label>Fecha inicio de vigencia</label><input name="fecha_inicio_vigencia" type="date" required /></div>
        <div><label>Fecha fin de vigencia</label><input name="fecha_fin_vigencia" type="date" /></div>
      </div>
      <div class="two-cols">
        <div>
          <label>Sala</label>
          <select name="sala_id" required>
            <option value="">Selecciona una sala</option>
            ${salasList.map((sala) => `<option value="${Number(sala.id)}">${h(sala.nombre)} (${Number(sala.capacidad_total)} asientos)</option>`).join('')}
          </select>
        </div>
        <div><label>Precio entrada</label><input name="precio" type="number" step="0.01" placeholder="35.00" required /></div>
      </div>
      <div class="two-cols">
        <div><label>Estado</label><select name="estado"><option selected>ACTIVA</option><option>INACTIVA</option><option>PROXIMAMENTE</option></select></div>
        <div><label>Promoción</label><input name="promocion" placeholder="Texto promocional" /></div>
      </div>
      <label>ID género</label>
      <input name="genero_id" type="number" placeholder="Ej. 1" />
      <button class="btn btn-primary btn-full" type="submit">Guardar película</button>
    </form>

    <div class="table-card">
      <div class="table-header">
        <h2>Listado</h2>
        <span>${lista.length} registros</span>
      </div>
      <div class="responsive-table">
        <table>
          <thead><tr><th>Título</th><th>Género</th><th>Clasificación</th><th>Estado</th><th>Acción</th></tr></thead>
          <tbody>
            ${lista.map((pelicula) => `
              <tr>
                <td><strong>${h(pelicula.titulo)}</strong><small>${h((pelicula.sinopsis || '').slice(0, 85))}</small></td>
                <td>${h(pelicula.genero || 'Sin género')}</td>
                <td><span class="badge">${h(pelicula.clasificacion || 'S/C')}</span></td>
                <td><span class="status ${pelicula.estado === 'ACTIVA' ? 'status-ok' : 'status-warning'}">${h(pelicula.estado || 'ACTIVA')}</span></td>
                <td>
                  ${pelicula.estado === 'INACTIVA' ? `
                    <form method="POST" action="/admin/peliculas/${Number(pelicula.id)}/activar" style="display:inline-block; margin-right:8px;">
                      <button class="btn btn-secondary btn-small" type="submit">Activar</button>
                    </form>
                  ` : `
                    <form method="POST" action="/admin/peliculas/${Number(pelicula.id)}/eliminar" data-confirm="¿Inactivar esta película?" style="display:inline-block; margin-right:8px;">
                      <button class="btn btn-danger btn-small" type="submit">Inactivar</button>
                    </form>
                  `}
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    </div>
  </section>
`; %>
<%- include('layout', { title, user, body: content }) %>
