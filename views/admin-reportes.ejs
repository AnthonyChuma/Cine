<%
const money = (value) => Number(value || 0).toFixed(2);
const data = resumen || { ventas: 0, tickets: 0, usuarios: 0, peliculas: 0 };
const listaReportes = Array.isArray(reportes) ? reportes : [];
const content = `
  <section class="page-heading compact-heading">
    <span class="eyebrow">Reportes</span>
    <h1>Resumen del sistema</h1>
    <p>Indicadores principales y ventas por película.</p>
  </section>
  <section class="stats-grid">
    <article class="stat-card big"><span>Ventas acumuladas</span><strong>Bs ${money(data.ventas)}</strong></article>
    <article class="stat-card big"><span>Tickets vendidos</span><strong>${data.tickets || 0}</strong></article>
    <article class="stat-card big"><span>Usuarios registrados</span><strong>${data.usuarios || 0}</strong></article>
    <article class="stat-card big"><span>Películas activas</span><strong>${data.peliculas || 0}</strong></article>
  </section>
  ${listaReportes.length ? `
    <section class="section-block">
      <div class="section-title-row">
        <div>
          <span class="eyebrow">Ventas por película</span>
          <h2>Tickets vendidos e ingresos</h2>
        </div>
      </div>
      <div class="responsive-table">
        <table>
          <thead><tr><th>Película</th><th>Entradas vendidas</th><th>Ingresos</th><th>Funciones</th><th>Asientos</th></tr></thead>
          <tbody>
            ${listaReportes.map((row) => `
              <tr>
                <td>${h(row.pelicula)}</td>
                <td>${Number(row.entradas_vendidas)}</td>
                <td>Bs ${money(row.ingresos_totales)}</td>
                <td>${Array.isArray(row.funciones) ? row.funciones.join(', ') : h(row.funciones)}</td>
                <td>${Array.isArray(row.asientos_vendidos) ? row.asientos_vendidos.join(', ') : h(row.asientos_vendidos)}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    </section>
  ` : ''}
`; %>
<%- include('layout', { title, user, body: content }) %>
