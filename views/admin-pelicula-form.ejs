<%
const h = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
const content = `
  <section class="page-heading compact-heading">
    <span class="eyebrow">Administración</span>
    <h1>Nueva película</h1>
    <p>Agrega una película vigente con funciones automáticas en sala y horarios fijos.</p>
  </section>
  <section class="auth-page wide-auth">
    <div class="auth-card">
      <form method="POST" action="/admin/peliculas" class="form-grid">
        <label>Título</label>
        <input name="titulo" placeholder="Título de la película" required />
        <label>Sinopsis</label>
        <textarea name="sinopsis" placeholder="Descripción breve"></textarea>

        <div class="two-cols">
          <div>
            <label>Duración (min)</label>
            <input name="duracion_minutos" type="number" min="1" required />
          </div>
          <div>
            <label>Clasificación</label>
            <input name="clasificacion" placeholder="ATP, +14" required />
          </div>
        </div>

        <label>Género ID</label>
        <input name="genero_id" type="number" placeholder="Ej. 1" />
        <div class="two-cols">
          <div>
            <label>Fecha inicio de vigencia</label>
            <input name="fecha_inicio_vigencia" type="date" required />
          </div>
          <div>
            <label>Fecha fin de vigencia</label>
            <input name="fecha_fin_vigencia" type="date" />
          </div>
        </div>

        <label>Sala</label>
        <select name="sala_id" required>
          <option value="">Selecciona una sala</option>
          ${salas.map((sala) => `<option value="${Number(sala.id)}">${h(sala.nombre)} (${Number(sala.capacidad_total)} asientos)</option>`).join('')}
        </select>

        <label>Precio por entrada</label>
        <input name="precio" type="number" step="0.01" min="0" placeholder="Bs 35.00" required />

        <label>URL de imagen</label>
        <input name="imagen_url" placeholder="https://..." />
        <label>URL de tráiler</label>
        <input name="trailer_url" placeholder="https://..." />

        <div class="two-cols">
          <div>
            <label>Estado</label>
            <select name="estado">
              <option selected>ACTIVA</option>
              <option>INACTIVA</option>
              <option>PROXIMAMENTE</option>
            </select>
          </div>
          <div>
            <label>Promoción</label>
            <input name="promocion" placeholder="Texto promocional" />
          </div>
        </div>

        <button class="btn btn-primary btn-full" type="submit">Crear película</button>
      </form>
    </div>
  </section>
`;
%>
<%- include('layout', { title, user, body: content }) %>
