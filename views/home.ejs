<% const h = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
const short = (value, size = 120) => {
  const text = String(value ?? 'Sin sinopsis disponible.');
  return text.length > size ? `${text.slice(0, size).trim()}...` : text;
};
const peliculasList = Array.isArray(peliculas) ? peliculas : [];
const content = `
  <section class="hero hero-cinema">
    <div class="hero-copy">
      <span class="eyebrow">Cine Hispano Potosí</span>
      <h1>Compra tus tickets de cine en una sola plataforma.</h1>
      <p>Consulta la cartelera, elige tu función y accede a una experiencia rápida, segura y organizada.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/cartelera">Ver cartelera</a>
        <a class="btn btn-secondary" href="/login">Ingresar</a>
      </div>
    </div>
    <div class="hero-poster" aria-hidden="true">
      <div class="poster-card">
        <span class="poster-badge">ESTRENO</span>
        <div class="poster-icon">🍿</div>
        <h3>Funciones disponibles</h3>
        <p>Horarios, salas y tickets listos para comprar.</p>
      </div>
    </div>
  </section>

  <section class="page-heading">
    <span class="eyebrow">Cartelera vigente</span>
    <h1>Películas en exhibición</h1>
    <p>Solo se muestran películas activas y con funciones disponibles.</p>
  </section>

  <section class="movie-grid">
    ${peliculasList.length ? peliculasList.map((pelicula) => `
      <article class="movie-card">
        <div class="movie-poster ${pelicula.imagen_url ? '' : 'poster-empty'}">
          ${pelicula.imagen_url ? `<img src="${h(pelicula.imagen_url)}" alt="${h(pelicula.titulo)}" loading="lazy" />` : '<span>🎬</span>'}
          <span class="movie-status">${h(pelicula.estado || 'ACTIVA')}</span>
        </div>
        <div class="movie-body">
          <h3>${h(pelicula.titulo)}</h3>
          <p>${h(short(pelicula.sinopsis))}</p>
          <div class="movie-meta">
            <span>${h(pelicula.genero || 'Sin género')}</span>
            <span>${h(pelicula.clasificacion || 'S/C')}</span>
          </div>
          <a class="btn btn-primary btn-full" href="/pelicula/${Number(pelicula.id)}">Ver funciones</a>
        </div>
      </article>
    `).join('') : `
      <div class="empty-state">
        <span>🎬</span>
        <h3>No hay películas vigentes</h3>
        <p>Por el momento no hay funciones activas. Vuelve pronto.</p>
      </div>
    `}
  </section>
`; %>
<%- include('layout', { title, user, body: content }) %>
