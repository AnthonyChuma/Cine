<%
const h = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
const money = (value) => Number(value || 0).toFixed(2);
const lista = Array.isArray(tickets) ? tickets : [];
const content = `
  <section class="page-heading compact-heading">
    <span class="eyebrow">Cliente</span>
    <h1>Mis tickets</h1>
    <p>Consulta tus compras y códigos de acceso a sala.</p>
  </section>
  <section class="ticket-grid">
    ${lista.length ? lista.map((ticket) => `
      <article class="ticket-card">
        <div class="ticket-strip"></div>
        <div class="ticket-content">
          <span class="badge">${h(ticket.estado)}</span>
          <h3>${h(ticket.pelicula)}</h3>
          <p><strong>Código:</strong> ${h(ticket.codigo_unico)}</p>
          <p><strong>Fecha:</strong> ${h(ticket.fecha)} | <strong>Hora:</strong> ${h(ticket.hora_inicio)}</p>
          <p><strong>Asiento:</strong> ${h(ticket.fila)}${h(ticket.numero)}</p>
          <p><strong>Total:</strong> Bs ${money(ticket.total)}</p>
        </div>
      </article>
    `).join('') : `
      <div class="empty-state">
        <span>🎟️</span>
        <h3>Aún no tienes tickets</h3>
        <p>Visita la cartelera y compra tu primera entrada.</p>
        <a class="btn btn-primary" href="/cartelera">Ver cartelera</a>
      </div>
    `}
  </section>
`; %>
<%- include('layout', { title, user, body: content }) %>
